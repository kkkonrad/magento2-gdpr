<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="customer_account_navigation">
            <block class="Kkkonrad\Gdpr\Block\Privacy\NavigationLink"
                   name="customer-account-navigation-gdpr"
                   after="customer-account-navigation-account-link">
                <arguments>
                    <argument name="label" xsi:type="string" translate="true">Privacy and personal data</argument>
                    <argument name="path" xsi:type="string">gdpr/privacy/index</argument>
                    <argument name="sortOrder" xsi:type="number">210</argument>
                </arguments>
            </block>
        </referenceBlock>
    </body>
</page>
