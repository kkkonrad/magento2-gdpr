        <legend class="admin__legend"><span><?= $escaper->escapeHtml(__('Create consent draft')) ?></span></legend>
        <input class="admin__control-text" name="code" required placeholder="code">
        <input class="admin__control-text" name="name" required placeholder="<?= $escaper->escapeHtmlAttr(__('Internal name')) ?>">
        <select class="admin__control-select" name="location">
