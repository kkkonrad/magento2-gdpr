<?php
declare(strict_types=1);

use Kkkonrad\Gdpr\Block\Adminhtml\Request\Grid;
use Kkkonrad\Gdpr\Domain\DataRights\Request\RequestStatus;
use Magento\Framework\Escaper;

/** @var Grid $block */
/** @var Escaper $escaper */
?>
<div class="admin__data-grid-wrap">
    <table class="data-grid">
        <thead><tr>
            <th class="data-grid-th"><?= $escaper->escapeHtml(__('ID')) ?></th>
            <th class="data-grid-th"><?= $escaper->escapeHtml(__('Customer ID')) ?></th>
            <th class="data-grid-th"><?= $escaper->escapeHtml(__('Type')) ?></th>
            <th class="data-grid-th"><?= $escaper->escapeHtml(__('Status')) ?></th>
            <th class="data-grid-th"><?= $escaper->escapeHtml(__('Created')) ?></th>
            <th class="data-grid-th"><?= $escaper->escapeHtml(__('Decision')) ?></th>
        </tr></thead>
        <tbody>
        <?php foreach ($block->getRequests() as $request): ?>
            <tr class="data-row">
                <td><?= $escaper->escapeHtml($request['public_id']) ?></td>
                <td><?= (int)$request['customer_id'] ?></td>
                <td><?= $escaper->escapeHtml($request['type']) ?></td>
                <td><?= $escaper->escapeHtml($request['status']) ?></td>
                <td><?= $escaper->escapeHtml($request['created_at']) ?></td>
                <td>
                    <?php if ($request['status'] === RequestStatus::PENDING_APPROVAL): ?>
                        <form method="post" action="<?= $escaper->escapeUrl($block->getUrl('*/*/approve')) ?>">
                            <?= $block->getBlockHtml('formkey') ?>
                            <input type="hidden" name="request_id" value="<?= (int)$request['request_id'] ?>">
                            <input class="admin__control-text" name="public_reason" required
                                   placeholder="<?= $escaper->escapeHtmlAttr(__('Customer-safe reason')) ?>">
                            <input class="admin__control-text" name="admin_reason" required
                                   placeholder="<?= $escaper->escapeHtmlAttr(__('Administrative reason')) ?>">
                            <button class="action-primary" type="submit"><?= $escaper->escapeHtml(__('Approve')) ?></button>
                        </form>
                        <form method="post" action="<?= $escaper->escapeUrl($block->getUrl('*/*/reject')) ?>">
                            <?= $block->getBlockHtml('formkey') ?>
                            <input type="hidden" name="request_id" value="<?= (int)$request['request_id'] ?>">
                            <input class="admin__control-text" name="public_reason" required
                                   placeholder="<?= $escaper->escapeHtmlAttr(__('Customer-safe reason')) ?>">
                            <input class="admin__control-text" name="admin_reason" required
                                   placeholder="<?= $escaper->escapeHtmlAttr(__('Administrative reason')) ?>">
                            <button type="submit"><?= $escaper->escapeHtml(__('Reject')) ?></button>
                        </form>
                    <?php elseif (in_array($request['status'], [RequestStatus::FAILED, RequestStatus::PARTIALLY_COMPLETED], true)): ?>
                        <form method="post" action="<?= $escaper->escapeUrl($block->getUrl('*/*/retry')) ?>">
                            <?= $block->getBlockHtml('formkey') ?>
                            <input type="hidden" name="request_id" value="<?= (int)$request['request_id'] ?>">
                            <input class="admin__control-text" name="admin_reason" required
                                   placeholder="<?= $escaper->escapeHtmlAttr(__('Administrative retry reason')) ?>">
                            <button type="submit"><?= $escaper->escapeHtml(__('Retry')) ?></button>
                        </form>
                    <?php endif; ?>
                </td>
            </tr>
        <?php endforeach; ?>
        </tbody>
    </table>
</div>
