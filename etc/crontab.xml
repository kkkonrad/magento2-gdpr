<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="kkkonrad_gdpr_process_notifications" instance="Kkkonrad\Gdpr\Cron\ProcessNotificationOutbox" method="execute">
            <schedule>*/5 * * * *</schedule>
        </job>
        <job name="kkkonrad_gdpr_process_jobs" instance="Kkkonrad\Gdpr\Cron\ProcessJobs" method="execute">
            <schedule>* * * * *</schedule>
        </job>
        <job name="kkkonrad_gdpr_schedule_retention"
             instance="Kkkonrad\Gdpr\Cron\ScheduleRetention"
             method="execute">
            <schedule>15 2 * * *</schedule>
        </job>
        <job name="kkkonrad_gdpr_cleanup_expired_exports"
             instance="Kkkonrad\Gdpr\Cron\CleanupExpiredExports"
             method="execute">
            <schedule>35 * * * *</schedule>
        </job>
    </group>
</config>
