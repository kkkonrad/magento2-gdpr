<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Kkkonrad_Gdpr::gdpr" title="GDPR" sortOrder="85">
                    <resource id="Kkkonrad_Gdpr::configuration" title="Configuration" sortOrder="10"/>
                    <resource id="Kkkonrad_Gdpr::requests" title="Requests" sortOrder="20">
                        <resource id="Kkkonrad_Gdpr::requests_view" title="View requests" sortOrder="10"/>
                        <resource id="Kkkonrad_Gdpr::requests_decide" title="Approve or reject requests" sortOrder="20"/>
                        <resource id="Kkkonrad_Gdpr::requests_retry" title="Retry failed requests" sortOrder="30"/>
                        <resource id="Kkkonrad_Gdpr::requests_export" title="Export request list" sortOrder="40"/>
                        <resource id="Kkkonrad_Gdpr::requests_export_on_behalf"
                                  title="Create customer data exports"
                                  sortOrder="50"/>
                    </resource>
                    <resource id="Kkkonrad_Gdpr::consents" title="Consents" sortOrder="30">
                        <resource id="Kkkonrad_Gdpr::consents_view" title="View consents" sortOrder="10"/>
                        <resource id="Kkkonrad_Gdpr::consents_manage" title="Manage consent definitions" sortOrder="20"/>
                    </resource>
                    <resource id="Kkkonrad_Gdpr::cookies" title="Cookies" sortOrder="40">
                        <resource id="Kkkonrad_Gdpr::cookies_view" title="View cookies and detections" sortOrder="10"/>
                        <resource id="Kkkonrad_Gdpr::cookies_manage" title="Manage cookie catalog" sortOrder="20"/>
                    </resource>
                    <resource id="Kkkonrad_Gdpr::audit_view" title="View audit trail" sortOrder="50"/>
                    <resource id="Kkkonrad_Gdpr::health_view" title="View automation health" sortOrder="60"/>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
