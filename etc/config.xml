<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <kkkonrad_gdpr>
            <general>
                <enabled>0</enabled>
            </general>
            <data_rights>
                <dashboard_enabled>1</dashboard_enabled>
                <export_request_enabled>0</export_request_enabled>
                <anonymization_request_enabled>0</anonymization_request_enabled>
                <erasure_request_enabled>0</erasure_request_enabled>
                <retention_old_orders_enabled>0</retention_old_orders_enabled>
                <retention_old_orders_days>1825</retention_old_orders_days>
                <retention_abandoned_accounts_enabled>0</retention_abandoned_accounts_enabled>
                <retention_abandoned_accounts_days>1825</retention_abandoned_accounts_days>
                <export_ttl_hours>24</export_ttl_hours>
                <batch_size>100</batch_size>
            </data_rights>
            <consent>
                <enabled>0</enabled>
                <registration_enabled>0</registration_enabled>
                <newsletter_enabled>0</newsletter_enabled>
                <contact_enabled>0</contact_enabled>
                <checkout_enabled>0</checkout_enabled>
            </consent>
            <cookie>
                <enabled>0</enabled>
                <disabled_fallback>deny_optional</disabled_fallback>
                <banner_enabled>1</banner_enabled>
                <rejected_tracking_enabled>0</rejected_tracking_enabled>
                <track_unknown_only>1</track_unknown_only>
                <geolocation_enabled>0</geolocation_enabled>
                <consent_lifetime_days>180</consent_lifetime_days>
            </cookie>
            <google_consent>
                <enabled>0</enabled>
                <implementation_mode>advanced</implementation_mode>
                <ad_storage>denied</ad_storage>
                <analytics_storage>denied</analytics_storage>
                <functionality_storage>denied</functionality_storage>
                <personalization_storage>denied</personalization_storage>
                <security_storage>granted</security_storage>
                <ad_user_data>denied</ad_user_data>
                <ad_personalization>denied</ad_personalization>
                <debug_enabled>0</debug_enabled>
            </google_consent>
        </kkkonrad_gdpr>
    </default>
</config>
